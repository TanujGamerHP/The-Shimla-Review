generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User & Role Management
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  firebaseUid  String?  @unique
  name         String
  passwordHash String?
  role         String   @default("READER") // SUPER_ADMIN, EDITOR, REVIEWER, AUTHOR, CONTRIBUTOR, READER
  bio          String?
  avatarUrl    String?
  followers    Int      @default(0)
  following    Int      @default(0)
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  articles       Article[]
  books          Book[]
  poems          Poem[]
  researchPapers ResearchPaper[]
  comments       Comment[]
  bookmarks      Bookmark[]
  readingHistory ReadingHistory[]
  submissions    Submission[]
  notifications  Notification[]
}

// Content Modules
model Article {
  id            String    @id @default(cuid())
  title         String
  subtitle      String?
  slug          String    @unique
  content       String // Rich Text / Markdown
  coverImageUrl String?
  readingTime   Int?
  views         Int       @default(0)
  status        String    @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  tags       Tag[]
  comments   Comment[]
  bookmarks  Bookmark[]
}

model Book {
  id              String    @id @default(cuid())
  title           String
  synopsis        String?
  slug            String    @unique
  coverImageUrl   String?
  publisher       String?
  publicationDate DateTime?
  isbn            String?
  readingLevel    String?
  purchaseUrl     String?
  downloadUrl     String?
  price           Float?
  views           Int       @default(0)
  status          String    @default("DRAFT")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  bookmarks  Bookmark[]
}

model Poem {
  id        String   @id @default(cuid())
  title     String
  content   String
  slug      String   @unique
  language      String?
  audioUrl      String?
  coverImageUrl String?
  downloadUrl   String?
  views         Int      @default(0)
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  bookmarks  Bookmark[]
}

model ResearchPaper {
  id          String   @id @default(cuid())
  title       String
  abstract      String?
  slug          String   @unique
  doi           String?
  coverImageUrl String?
  downloadUrl   String?
  previewUrl    String?
  views         Int      @default(0)
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  bookmarks  Bookmark[]
}

model Journal {
  id              String    @id @default(cuid())
  title           String
  volume          String?
  issue           String?
  slug            String    @unique
  coverImageUrl   String?
  editorialBoard  String?
  downloadUrl     String?
  publicationDate DateTime?
  price           Float?
  views           Int       @default(0)
  status          String    @default("DRAFT")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Taxonomy
model Category {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  description    String?
  articles       Article[]
  books          Book[]
  poems          Poem[]
  researchPapers ResearchPaper[]
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[]
}

// Submissions (Work in progress)
model Submission {
  id                String   @id @default(cuid())
  trackingId        String   @unique
  fullName          String
  authorBio         String?
  email             String
  phone             String?
  country           String?
  city              String?
  profilePhotoUrl   String?
  socialLinks       String?
  website           String?
  submissionType    String
  category          String?
  language          String?
  title             String
  subtitle          String?
  description       String?
  keywords          String?
  coverImageUrl     String?
  documentUrl       String?
  wordCount         Int?
  readingTime       Int?
  consentGiven      Boolean  @default(false)
  copyrightDeclared Boolean  @default(false)
  originalWork      Boolean  @default(false)
  status            String   @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, REJECTED, NEEDS_REVISION
  internalNotes     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

// Engagement & Community
model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id])
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  articleId       String?
  article         Article?       @relation(fields: [articleId], references: [id])
  bookId          String?
  book            Book?          @relation(fields: [bookId], references: [id])
  poemId          String?
  poem            Poem?          @relation(fields: [poemId], references: [id])
  researchPaperId String?
  researchPaper   ResearchPaper? @relation(fields: [researchPaperId], references: [id])
}

model ReadingHistory {
  id          String   @id @default(cuid())
  contentId   String
  contentType String // ARTICLE, BOOK, POEM, RESEARCH
  lastReadAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// Media & Operations
model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int // in bytes
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  subscribed Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String
  details     String?
  performedBy String?
  createdAt   DateTime @default(now())
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// To support the legacy clone PaperItem component
model Paper {
  id           String   @id @default(cuid())
  title        String
  abstract     String?
  type         String   @default("Paper")
  institution  String?
  year         Int?
  views        Int      @default(0)
  downloadUrl  String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
