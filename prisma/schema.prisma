generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User & Role Management
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  firebaseUid  String?  @unique
  name         String
  passwordHash String?
  role         String   @default("READER") // SUPER_ADMIN, EDITOR, REVIEWER, AUTHOR, CONTRIBUTOR, READER
  bio          String?
  avatarUrl    String?
  followers    Int      @default(0)
  following    Int      @default(0)
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  books          Book[]
  researchPapers ResearchPaper[]
  studentNotes   StudentNote[]
  miscWorks      MiscWork[]
  comments       Comment[]
  bookmarks      Bookmark[]
  readingHistory ReadingHistory[]
  notifications  Notification[]
}

// Content Modules
model Book {
  id              String    @id @default(cuid())
  title           String
  subtitle        String?
  synopsis        String?
  slug            String    @unique
  coverImageUrl   String?
  publisher       String?
  publicationDate DateTime?
  isbn            String?
  readingLevel    String?
  purchaseUrl     String?
  downloadUrl     String?
  price           Float?
  views           Int       @default(0)
  downloads       Int       @default(0)
  status          String    @default("DRAFT")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  bookmarks  Bookmark[]
}

model ResearchPaper {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  abstract    String?
  slug          String   @unique
  doi           String?
  coverImageUrl String?
  downloadUrl   String?
  previewUrl    String?
  views         Int      @default(0)
  downloads     Int      @default(0)
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  bookmarks  Bookmark[]
}

model StudentNote {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  description   String?
  slug          String   @unique
  subject       String?
  coverImageUrl String?
  downloadUrl   String?
  views         Int      @default(0)
  downloads     Int      @default(0)
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  bookmarks  Bookmark[]
}

model MiscWork {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  description   String?
  slug          String   @unique
  subject       String?
  coverImageUrl String?
  downloadUrl   String?
  views         Int      @default(0)
  downloads     Int      @default(0)
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  categoryId String?
  category   Category?  @relation(fields: [categoryId], references: [id])
  bookmarks  Bookmark[]
}

// Taxonomy
model Category {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  description    String?
  books          Book[]
  researchPapers ResearchPaper[]
  studentNotes   StudentNote[]
  miscWorks      MiscWork[]
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
}

// Engagement & Community
model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  bookId          String?
  book            Book?          @relation(fields: [bookId], references: [id])
  researchPaperId String?
  researchPaper   ResearchPaper? @relation(fields: [researchPaperId], references: [id])
  studentNoteId   String?
  studentNote     StudentNote?   @relation(fields: [studentNoteId], references: [id])
  miscWorkId      String?
  miscWork        MiscWork?      @relation(fields: [miscWorkId], references: [id])
}

model ReadingHistory {
  id          String   @id @default(cuid())
  contentId   String
  contentType String // BOOK, RESEARCH, STUDENT_NOTE
  lastReadAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// Media & Operations
model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int // in bytes
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  subscribed Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String
  details     String?
  performedBy String?
  createdAt   DateTime @default(now())
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// To support the legacy clone PaperItem component
model Paper {
  id           String   @id @default(cuid())
  title        String
  abstract     String?
  type         String   @default("Paper")
  institution  String?
  year         Int?
  views        Int      @default(0)
  downloadUrl  String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
